# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- Secrets / local-only config ---------------------------------------------
# The `.env` file holds Supabase credentials for the current machine and must
# never be committed. `.env.example` IS tracked as the shared template.
.env
.env.local
.env.*.local

# Supabase CLI local cache (machine-specific; do not commit)
supabase/.temp/

