# -----------------------------------------------------------------------------
# NetworkWise — environment configuration template
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` in the project root (same folder as pubspec.yaml).
# 2. Fill in the values from:
#       Supabase Dashboard  →  Project Settings  →  API
# 3. The `.env` file is bundled as a Flutter asset (see pubspec.yaml). It is
#    git-ignored — never commit real credentials.
#
# IMPORTANT — only CLIENT-SAFE keys belong in this file.
#   * SUPABASE_ANON_KEY is safe for the client because Row Level Security
#     policies on every table determine what it can actually read / write.
#   * The SERVICE ROLE key must NEVER appear here. It lives only in:
#       - Supabase Edge Function secrets, or
#       - your dashboard / admin backend.
# -----------------------------------------------------------------------------

# -------- Required --------
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your.anon.public.key...xxxxx

# -------- Optional / future --------
# Slug of the tenant this endpoint belongs to. Used by the device
# registration Edge Function to attach new devices to the right org.
APP_ORG_SLUG=mistry-and-shah

# Environment label — stamped on every heartbeat + alert for filtering.
# Accepted values: development | staging | production
APP_ENV=development

# Install role — controls the first-run experience:
#   endpoint  (default) → enrols this PC, ships heartbeats for itself only.
#   admin               → adds a Supabase Auth sign-in gate + fleet-wide
#                         management UI (rename device, rotate enrollment
#                         code, invite admins).
# Build one installer per role so each site gets the correct behaviour.
APP_ROLE=endpoint

# Overrides the compile-time default (30 s). Only used if you want to
# pre-seed a specific cadence before the user touches the Settings UI.
APP_HEARTBEAT_SECONDS=30
